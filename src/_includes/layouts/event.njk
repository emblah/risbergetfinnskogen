---
layout: layouts/base.njk
---
{% set images = eventGalleries[eventGallery] %}
<article class="content-shell flow">
  <header class="page-header flow">
    <p class="eyebrow">Arrangementarkiv</p>
    <h1>{{ title }}</h1>
    {% if introduction %}<p class="introduction">{{ introduction }}</p>{% endif %}
  </header>
  <div class="prose flow">
    {{ content | safe }}
  </div>
  {% if images %}
    <section aria-labelledby="event-gallery-heading">
      <h2 id="event-gallery-heading">Bilder fra arrangementet</h2>
      <div class="gallery" role="list">
        {% for image in images %}
          <figure role="listitem">
            <a href="{{ image.src }}" data-lightbox aria-label="Åpne større bilde: {{ image.alt }}">
              <img
                src="{{ image.src }}"
                alt="{{ image.alt }}"
                width="{{ image.width }}"
                height="{{ image.height }}"
                loading="lazy">
            </a>
            {% if image.caption %}<figcaption>{{ image.caption }}</figcaption>{% endif %}
          </figure>
        {% endfor %}
      </div>
    </section>
  {% endif %}
</article>
