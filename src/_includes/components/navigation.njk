<nav id="site-navigation" class="site-navigation" aria-label="Hovedmeny">
  <ul>
    {% for item in navigation %}
      <li{% if item.children %} class="has-children"{% endif %}>
        <a href="{{ item.url }}"{% if page.url == item.url %} aria-current="page"{% endif %}>{{ item.label }}</a>
        {% if item.children %}
          <ul>
            {% for child in item.children %}
              <li>
                <a href="{{ child.url }}"{% if page.url == child.url %} aria-current="page"{% endif %}>{{ child.label }}</a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</nav>
